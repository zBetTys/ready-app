  void _loadUserData() {
    final args = ModalRoute.of(context)?.settings.arguments;
    if (args != null && args is Map<String, dynamic>) {
      setState(() {
        _userData = args;
      });
      print("📥 รับข้อมูลจาก Register: $_userData");
    }
  }

  Future<void> _saveConsentAndNavigate() async {
    if (!_hasReadAll || _userData == null) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(_userData == null 
            ? "ไม่พบข้อมูลการสมัคร กรุณาลองใหม่อีกครั้ง" 
            : "กรุณาอ่านและยอมรับข้อตกลงทั้งหมด"),
          backgroundColor: Colors.red,
        ),
      );
      return;
    }

    setState(() {
      _isSaving = true;
      _isCreatingAccount = true;
    });

    try {
      // 1. สร้างบัญชีใน Firebase Auth
      final email = _userData!['email'] as String;
      final password = _userData!['password'] as String;
      
      print("📝 กำลังสร้างบัญชีสำหรับ: $email");
      
      final userCredential = await _auth.createUserWithEmailAndPassword(
        email: email,
        password: password,
      );
      
      final user = userCredential.user!;
      print("✅ สร้างบัญชีสำเร็จ: ${user.uid}");
      
      // 2. ส่งอีเมลยืนยัน
      await user.sendEmailVerification();
      print("📧 ส่งอีเมลยืนยันแล้ว");
      
      // 3. บันทึกข้อมูลใน Firestore
      final userDocument = {
        'studentId': _userData!['studentId'],
        'firstName': _userData!['firstName'],
        'lastName': _userData!['lastName'],
        'level': _userData!['level'],
        'year': _userData!['year'],
        'email': email,
        'emailVerified': false, // ยังไม่ได้ยืนยันอีเมล
        'pdpaConsent': true,
        'pdpaConsentDate': FieldValue.serverTimestamp(),
        'pdpaVersion': '1.0',
        'createdAt': FieldValue.serverTimestamp(),
        'updatedAt': FieldValue.serverTimestamp(),
        'faceRegistered': false,
        'role': 'student',
        'status': 'pending', // รอการยืนยันอีเมล
        'lastLogin': FieldValue.serverTimestamp(),
        'registrationComplete': true,
      };
      
      await _firestore.collection('users').doc(user.uid).set(userDocument);
      print("💾 บันทึกข้อมูลใน Firestore สำเร็จ");
      
      // 4. แสดงผลสำเร็จ
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text("✅ สมัครสมาชิกสำเร็จ! กรุณาตรวจสอบอีเมลเพื่อยืนยันบัญชี"),
          backgroundColor: Colors.green,
          duration: Duration(seconds: 5),
        ),
      );
      
      // 5. ออกจากระบบและนำทางไปหน้า Login หรือหน้าแรก
      await Future.delayed(Duration(seconds: 2));
      
      await _auth.signOut(); // ออกจากระบบเพื่อให้ผู้ใช้ล็อกอินใหม่หลังยืนยันอีเมล
      
      if (mounted) {
        // นำทางไปหน้า Login หรือหน้าแรก
        Navigator.pushNamedAndRemoveUntil(
          context, 
          '/login', // เปลี่ยนไปหน้า Login
          (route) => false
        );
      }
      
    } on FirebaseAuthException catch (e) {
      String errorMessage = "เกิดข้อผิดพลาดในการสร้างบัญชี";
      if (e.code == 'email-already-in-use') {
        errorMessage = "อีเมลนี้ถูกใช้งานแล้ว";
      } else if (e.code == 'weak-password') {
        errorMessage = "รหัสผ่านไม่แข็งแรงพอ";
      } else if (e.code == 'invalid-email') {
        errorMessage = "รูปแบบอีเมลไม่ถูกต้อง";
      } else if (e.code == 'network-request-failed') {
        errorMessage = "เชื่อมต่ออินเทอร์เน็ตล้มเหลว";
      } else if (e.code == 'too-many-requests') {
        errorMessage = "ร้องขอมากเกินไป กรุณารอสักครู่";
      }
      
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(errorMessage),
          backgroundColor: Colors.red,
        ),
      );
      
    } catch (e) {
      print("❌ เกิดข้อผิดพลาด: $e");
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text("เกิดข้อผิดพลาด: ${e.toString()}"),
          backgroundColor: Colors.red,
        ),
      );
    } finally {
      setState(() {
        _isSaving = false;
        _isCreatingAccount = false;
      });
    }
  }

