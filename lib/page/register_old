class RegisterPage extends StatefulWidget {
  const RegisterPage({super.key});

  @override
  State<RegisterPage> createState() => _RegisterPageState();
}

class _RegisterPageState extends State<RegisterPage> {
  final _auth = FirebaseAuth.instance;
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;

  // Controllers
  final TextEditingController _studentIdController = TextEditingController();
  final TextEditingController _firstNameController = TextEditingController();
  final TextEditingController _lastNameController = TextEditingController();
  final TextEditingController _emailController = TextEditingController();
  final TextEditingController _passwordController = TextEditingController();
  final TextEditingController _confirmPasswordController =
      TextEditingController();

  // Dropdown variables
  String? _selectedLevel;
  String? _selectedYear;

  // State variables
  bool _isLoading = false;
  bool _obscurePassword = true;
  bool _obscureConfirmPassword = true;
  bool _emailVerified = false;
  bool _isSendingVerification = false;
  bool _isCheckingVerification = false;
  int _resendTimer = 0;
  Timer? _timer;
  bool _showSuccessAnimation = false;
  bool _accountCreated = false;
  String? _tempUid;

  // Options
  final List<String> _educationLevels = ['ปวช.', 'ปวส.'];
  List<String> _yearLevels = ['1/1', '1/2', '2/1', '2/2', '3/1', '3/2'];

  // สีหลัก
  final Color _primaryDark = Color(0xFF4A148C);
  final Color _primaryColor = Color(0xFF6A1B9A);
  final Color _primaryMedium = Color(0xFF8E24AA);
  final Color _primaryLight = Color(0xFFAB47BC);
  final Color _primaryVeryLight = Color(0xFFE1BEE7);
  final Color _accentColor = Color(0xFFCE93D8);
  final Color _backgroundColor = Color(0xFFF8F4FF);
  final Color _cardColor = Colors.white;
  final Color _textColor = Color(0xFF4A148C);
  final Color _successColor = Color(0xFF66BB6A);
  final Color _errorColor = Color(0xFFEF5350);
  final Color _warningColor = Color(0xFFFFB74D);

  @override
  void initState() {
    super.initState();
    _emailController.addListener(_onEmailChanged);
    _startAuthListener();
  }

  @override
  void dispose() {
    _timer?.cancel();
    _emailController.removeListener(_onEmailChanged);
    super.dispose();
  }

  void _startAuthListener() {
    _auth.authStateChanges().listen((User? user) {
      if (user != null && _accountCreated) {
        _checkEmailVerificationStatus();
      }
    });
  }

  void _onEmailChanged() {
    if (_emailController.text.contains('@')) {
      setState(() {});
    }
  }

  void _startResendTimer() {
    _resendTimer = 60;
    _timer = Timer.periodic(Duration(seconds: 1), (timer) {
      if (_resendTimer > 0) {
        setState(() {
          _resendTimer--;
        });
      } else {
        timer.cancel();
      }
    });
  }

  void _updateYearLevels() {
    if (_selectedLevel == 'ปวส.') {
      _yearLevels = ['1/1', '1/2', '2/1', '2/2'];
    } else {
      _yearLevels = ['1/1', '1/2', '2/1', '2/2', '3/1', '3/2'];
    }

    if (_selectedYear != null && !_yearLevels.contains(_selectedYear)) {
      _selectedYear = null;
    }
  }

  bool _isDisposableEmail(String email) {
    final domain = email.split('@')[1].toLowerCase();
    final disposableDomains = [
      'tempmail.com',
      '10minutemail.com',
      'guerrillamail.com',
      'mailinator.com',
      'yopmail.com',
      'trashmail.com',
      'fakeinbox.com',
      'sharklasers.com',
      'guerillamail.info',
      'maildrop.cc',
      'getairmail.com',
      'temp-mail.org',
    ];
    return disposableDomains.contains(domain);
  }

  bool _validateForm() {
    if (_studentIdController.text.isEmpty ||
        _studentIdController.text.length != 11) {
      _showSnackBar("กรุณากรอกรหัสนักศึกษา 11 หลัก", _errorColor);
      return false;
    }

    if (_firstNameController.text.isEmpty) {
      _showSnackBar("กรุณากรอกชื่อจริง", _errorColor);
      return false;
    }

    if (_lastNameController.text.isEmpty) {
      _showSnackBar("กรุณากรอกนามสกุล", _errorColor);
      return false;
    }

    if (_selectedLevel == null) {
      _showSnackBar("กรุณาเลือกระดับการศึกษา", _errorColor);
      return false;
    }

    if (_selectedYear == null) {
      _showSnackBar("กรุณาเลือกชั้นปี", _errorColor);
      return false;
    }

    final email = _emailController.text.trim();
    if (email.isEmpty || !email.contains('@')) {
      _showSnackBar("กรุณากรอกอีเมลให้ถูกต้อง", _errorColor);
      return false;
    }

    final emailRegex = RegExp(r'^[\w-\.]+@([\w-]+\.)+[\w-]{2,4}$');
    if (!emailRegex.hasMatch(email)) {
      _showSnackBar("รูปแบบอีเมลไม่ถูกต้อง", _errorColor);
      return false;
    }

    if (_isDisposableEmail(email)) {
      _showSnackBar("ไม่อนุญาตให้ใช้อีเมลชั่วคราว", _errorColor);
      return false;
    }

    if (_passwordController.text.length < 6) {
      _showSnackBar("รหัสผ่านต้องมีอย่างน้อย 6 ตัวอักษร", _errorColor);
      return false;
    }

    if (_passwordController.text != _confirmPasswordController.text) {
      _showSnackBar("รหัสผ่านไม่ตรงกัน", _errorColor);
      return false;
    }

    return true;
  }

  void _showSnackBar(String message, Color color) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Row(
          children: [
            Icon(
              color == _successColor ? Icons.check_circle : Icons.error,
              color: Colors.white,
              size: 24,
            ),
            SizedBox(width: 12),
            Expanded(child: Text(message)),
          ],
        ),
        backgroundColor: color,
        behavior: SnackBarBehavior.floating,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
        duration: Duration(seconds: 3),
        padding: EdgeInsets.symmetric(horizontal: 20, vertical: 16),
        elevation: 10,
        showCloseIcon: true,
      ),
    );
  }

  Future<void> _createAccountAndSendVerification() async {
    if (!_validateForm()) return;

    FocusScope.of(context).unfocus();

    setState(() {
      _isLoading = true;
      _isSendingVerification = true;
    });

    try {
      final email = _emailController.text.trim();
      final password = _passwordController.text.trim();

      // 1. สร้างบัญชีผู้ใช้ใหม่
      final userCredential = await _auth.createUserWithEmailAndPassword(
        email: email,
        password: password,
      );

      final user = userCredential.user!;
      _tempUid = user.uid;

      // 2. ส่งอีเมลยืนยัน
      await user.sendEmailVerification();

      // 3. บันทึกข้อมูลใน Firestore (โดยไม่ต้องรอการยืนยันอีเมล)
      await _firestore.collection('users').doc(user.uid).set({
        'studentId': _studentIdController.text.trim(),
        'firstName': _firstNameController.text.trim(),
        'lastName': _lastNameController.text.trim(),
        'level': _selectedLevel,
        'year': _selectedYear,
        'email': email,
        'emailVerified': false, // ยังไม่ได้ยืนยัน
        'createdAt': FieldValue.serverTimestamp(),
        'updatedAt': FieldValue.serverTimestamp(),
        'faceRegistered': false,
        'role': 'student',
        'status': 'pending', // สถานะรอยืนยันอีเมล
        'lastLogin': FieldValue.serverTimestamp(),
      });

      setState(() {
        _accountCreated = true;
        _startResendTimer();
      });

      _showSnackBar(
        "✨ สร้างบัญชีและส่งลิงก์ยืนยันไปยังอีเมลแล้ว",
        _successColor,
      );

      // 4. ออกจากระบบชั่วคราว
      await _auth.signOut();
    } on FirebaseAuthException catch (e) {
      String errorMessage = "ไม่สามารถสร้างบัญชีได้";
      if (e.code == 'email-already-in-use') {
        errorMessage = "อีเมลนี้ถูกใช้งานแล้ว";
      } else if (e.code == 'weak-password') {
        errorMessage = "รหัสผ่านไม่แข็งแรงพอ";
      } else if (e.code == 'invalid-email') {
        errorMessage = "รูปแบบอีเมลไม่ถูกต้อง";
      } else if (e.code == 'network-request-failed') {
        errorMessage = "เชื่อมต่ออินเทอร์เน็ตล้มเหลว";
      } else if (e.code == 'too-many-requests') {
        errorMessage = "ร้องขอมากเกินไป กรุณารอสักครู่";
      }
      _showSnackBar(errorMessage, _errorColor);
    } catch (e) {
      _showSnackBar("เกิดข้อผิดพลาด: $e", _errorColor);
    } finally {
      setState(() {
        _isLoading = false;
        _isSendingVerification = false;
      });
    }
  }

  Future<void> _checkEmailVerificationStatus() async {
    if (!_accountCreated || _tempUid == null) return;

    setState(() => _isCheckingVerification = true);

    try {
      final user = _auth.currentUser;

      // หากยังไม่ได้ล็อกอิน ให้ล็อกอินเพื่อตรวจสอบ
      if (user == null) {
        final email = _emailController.text.trim();
        final password = _passwordController.text.trim();

        try {
          await _auth.signInWithEmailAndPassword(
            email: email,
            password: password,
          );
        } catch (e) {
          // ถ้าไม่สามารถล็อกอินได้ (เช่น รหัสผ่านผิด)
          return;
        }
      }

      final currentUser = _auth.currentUser;
      if (currentUser != null) {
        await currentUser.reload();
        final refreshedUser = _auth.currentUser;

        if (refreshedUser!.emailVerified) {
          setState(() {
            _emailVerified = true;
            _showSuccessAnimation = true;
          });

          // อัพเดทสถานะใน Firestore
          await _firestore.collection('users').doc(refreshedUser.uid).update({
            'emailVerified': true,
            'status': 'active',
            'updatedAt': FieldValue.serverTimestamp(),
          });

          _showSnackBar("🎉 ยืนยันอีเมลสำเร็จ!", _successColor);

          Future.delayed(Duration(seconds: 2), () {
            if (mounted) {
              setState(() {
                _showSuccessAnimation = false;
              });
              _navigateToPDPA(refreshedUser.uid);
            }
          });
        }
      }
    } catch (e) {
      // ไม่ต้องแสดง error
    } finally {
      setState(() => _isCheckingVerification = false);
    }
  }

  Future<void> _resendVerificationEmail() async {
    if (!_accountCreated) return;

    setState(() => _isSendingVerification = true);

    try {
      final email = _emailController.text.trim();
      final password = _passwordController.text.trim();

      // ล็อกอินเพื่อส่งอีเมลยืนยันใหม่
      await _auth.signInWithEmailAndPassword(email: email, password: password);

      final user = _auth.currentUser;
      if (user != null) {
        await user.sendEmailVerification();
        _showSnackBar("✨ ส่งลิงก์ยืนยันใหม่ไปยังอีเมลแล้ว", _successColor);

        setState(() {
          _startResendTimer();
        });

        // ออกจากระบบหลังส่งอีเมล
        await _auth.signOut();
      }
    } on FirebaseAuthException catch (e) {
      if (e.code == 'wrong-password' || e.code == 'user-not-found') {
        _showSnackBar(
          "ไม่สามารถส่งอีเมลยืนยันได้ กรุณาตรวจสอบข้อมูล",
          _errorColor,
        );
      } else {
        _showSnackBar("ไม่สามารถส่งลิงก์ยืนยันได้: ${e.message}", _errorColor);
      }
    } catch (e) {
      _showSnackBar("เกิดข้อผิดพลาด: $e", _errorColor);
    } finally {
      setState(() => _isSendingVerification = false);
    }
  }

  Future<void> _navigateToPDPA(String uid) async {
    await Future.delayed(Duration(milliseconds: 500));

    if (mounted) {
      Navigator.pushReplacement(
        context,
        MaterialPageRoute(
          builder: (context) => PDPAPage(),
          settings: RouteSettings(
            arguments: {
              'userId': uid,
              'studentId': _studentIdController.text.trim(),
              'email': _emailController.text.trim(),
            },
          ),
        ),
      );
    }
  }

  void _navigateToLogin() {
    Navigator.pop(context);
  }

